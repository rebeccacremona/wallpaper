# Tahoe Aerial Switcher -- shipped defaults.
#
# This file holds the SHIPPED DEFAULTS that travel with the bundle.
# Don't edit it for personal use -- your edits would (a) get overwritten
# by future updates and (b) leak into any zip you build for someone
# else.
#
# Personal customizations are written to:
#   _Private/State/user_config.env
# by the Change Settings.command (or you can hand-edit that file). The
# user override file is sourced AFTER this one, so any keys it sets win.

# Location used to compute sunrise/sunset (local NOAA formula, no network).
# LOCATION_LABEL is just a friendly name for display in Change Settings;
# only LAT, LNG, and TZ are used for actual computation.
LAT="42.3601"
LNG="-71.0589"
TZ="America/New_York"
LOCATION_LABEL="Boston / Massachusetts / United States"

# LaunchAgent label suffix. Final label will be "com.<your-username>.$LABEL_SUFFIX".
LABEL_SUFFIX="aerial.switcher"

# Window offsets, in minutes relative to sunrise / sunset.
#   morning_start = sunrise + MORNING_OFFSET_MIN  (negative = before sunrise)
#   day_start     = sunrise + DAY_OFFSET_MIN
#   evening_start = sunset  + EVENING_OFFSET_MIN  (negative = before sunset)
#   night_start   = sunset  + NIGHT_OFFSET_MIN
MORNING_OFFSET_MIN=-30
DAY_OFFSET_MIN=120
EVENING_OFFSET_MIN=-90
NIGHT_OFFSET_MIN=120

# How often the LaunchAgent runs the dispatcher while the Mac is awake.
# Common values: 300 (5 min), 900 (15 min), 1800 (30 min).
CHECK_INTERVAL_SECONDS=900
